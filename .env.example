REDMINE_URL=http://localhost:3000
REDMINE_API_KEY=your_redmine_api_key_here

# Beta mode — shows a notice in every AI response telling users where to report issues
# Set to "false" to disable when moving to production
REDMINEFLUX_BETA=true
REDMINEFLUX_FEEDBACK_PROJECT=ztmcp
# Optional: override the default beta notice message
# REDMINEFLUX_BETA_NOTICE=Custom message here
